// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// ユーザー・認証
// ===========================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  avatarUrl String?  @map("avatar_url")
  // 全体管理者（プラットフォーム管理者）。会社の作成等はこの権限のみ。
  isSuperAdmin Boolean @default(false) @map("is_super_admin")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organizationMembers OrganizationMember[]
  settings            UserSetting?
  apiKeys             ApiKey[]
  projectMemberships  ProjectMember[]

  @@map("users")
}

// プロジェクト単位のユーザー権限（閲覧 / 編集）。
// 実効権限: 全体管理者・会社 OWNER/ADMIN は常に EDIT。
// プロジェクトに ProjectMember 行が1件も無ければ、後方互換で全 org メンバー = EDIT。
// 行が存在する場合は、掲載ユーザーはその accessLevel、未掲載の org メンバーは権限なし。
enum ProjectAccessLevel {
  VIEW
  EDIT
}

model ProjectMember {
  id          String             @id @default(uuid())
  projectId   String             @map("project_id")
  userId      String             @map("user_id")
  accessLevel ProjectAccessLevel @default(EDIT) @map("access_level")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@map("project_members")
}

// バックグラウンドジョブ（AI生成の非同期化・定期ジョブの実行記録）。
// Upstash Redis をキュー/ロックに、本テーブルを永続ステータス/結果に使う。
enum BackgroundJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

model BackgroundJob {
  id          String              @id @default(uuid())
  projectId   String?             @map("project_id")
  // ジョブ種別（例: AI_MERMAID_FLOW / AI_MERMAID_OBJECTMAP / AI_KPI / AI_SCHEMA_ANALYZE / AI_ISSUE_SUGGEST）
  type        String
  status      BackgroundJobStatus @default(QUEUED)
  // 実行に必要な入力（リクエスト相当）。秘匿情報は入れない方針
  payload     Json?
  // 成功時の結果（クライアントがポーリングで取得）
  result      Json?
  // 最新（最終）試行のエラー。試行ごとの全履歴は BackgroundJobAttempt 参照
  error       String?             @db.Text
  progress    Int                 @default(0)
  // これまでの試行回数 / 自動リトライ上限
  attempts    Int                 @default(0)
  maxAttempts Int                 @default(3) @map("max_attempts")
  // 起票ユーザー（FKなし。任意）
  createdById String?             @map("created_by_id")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  startedAt   DateTime?           @map("started_at")
  finishedAt  DateTime?           @map("finished_at")

  project        Project?               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  attemptRecords BackgroundJobAttempt[]

  @@index([projectId, createdAt])
  @@index([status])
  @@map("background_jobs")
}

// 外部課題トラッカー（Backlog / Jira）接続。CSV不要のフル移行＋差分/定期同期に使う。
enum IssueTrackerProvider {
  BACKLOG
  JIRA
}

model IssueTrackerConnection {
  id            String               @id @default(uuid())
  projectId     String               @map("project_id")
  provider      IssueTrackerProvider
  // Backlog: スペースホスト（例 iplot.backlog.com）。Jira: サイトURL（例 https://xxx.atlassian.net）
  host          String
  // Jira のみ: 認証メールアドレス（Backlog は不要）
  email         String?
  // Backlog: APIキー / Jira: APIトークン。AES-256-GCM 暗号化保存。レスポンスでは返さない
  credentialEnc String               @map("credential_enc")
  // webhook 受信用の秘密トークン（AES-256-GCM 暗号化）。null=webhook 無効。URL に埋め込み timing-safe 照合。
  webhookSecretEnc String?           @map("webhook_secret_enc")
  // 取り込み対象のプロジェクトキー（Backlog projectKey / Jira project key）
  projectKey    String?              @map("project_key")
  lastSyncedAt  DateTime?            @map("last_synced_at")
  autoSync      Boolean              @default(false) @map("auto_sync")
  syncIntervalMinutes Int            @default(60) @map("sync_interval_minutes")
  status        String               @default("active")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("issue_tracker_connections")
}

// Webhook 設定（プロジェクトごとの送信先。ipro-kun 等の外部連携）。
// 配信自体は BackgroundJob(type=WEBHOOK_DELIVERY) に乗せ、自動リトライ＋試行記録を再利用する。
model Webhook {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  // 送信先URL（管理画面で設定）
  targetUrl  String   @map("target_url")
  // 署名用シークレット（AES-256-GCM 暗号化保存。HMAC-SHA256 署名に使用。レスポンスでは返さない）
  secretEnc  String?  @map("secret_enc")
  // 購読イベント（例: ["task.created","task.updated","task.status_changed","task.deleted"]）
  events     Json
  active     Boolean  @default(true)
  // 任意の表示名・補足
  label      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("webhooks")
}

// バックグラウンドジョブの「試行」1回ぶんの記録（リトライ回数とエラーを全て残す）。
model BackgroundJobAttempt {
  id         String              @id @default(uuid())
  jobId      String              @map("job_id")
  // 1始まりの試行番号
  attemptNo  Int                 @map("attempt_no")
  status     BackgroundJobStatus // RUNNING / SUCCEEDED / FAILED
  error      String?             @db.Text
  startedAt  DateTime            @default(now()) @map("started_at")
  finishedAt DateTime?           @map("finished_at")
  durationMs Int?                @map("duration_ms")

  job BackgroundJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, attemptNo])
  @@index([jobId])
  @@map("background_job_attempts")
}

// ===========================================
// 組織・プロジェクト
// ===========================================

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  // 会社ステータス
  status      String   @default("active") // active | suspended
  // 会社ごとの Anthropic APIキー（AES-256-GCM 暗号化）。AI機能の鍵解決で最優先。
  anthropicApiKeyEnc String? @map("anthropic_api_key_enc")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members  OrganizationMember[]
  projects Project[]

  @@map("organizations")
}

model OrganizationMember {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  userId         String     @map("user_id")
  role           MemberRole @default(MEMBER)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Project {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  slug           String
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tables        Table[]
  roles         Role[]
  businessFlows BusinessFlow[]
  requirements  Requirement[]
  phases        ProjectPhase[]
  issueTrees    IssueTree[]
  gapItems      GapItem[]
  apiKeys       ApiKey[]
  githubConnections GithubConnection[]
  apiEndpoints      ApiEndpoint[]
  subProjects       SubProject[]
  systems           System[]
  constraints       Constraint[]
  attachments       Attachment[]
  databaseConnections DatabaseConnection[]
  flowFolders       FlowFolder[]
  tasks             Task[]
  dfdDiagrams       DfdDiagram[]
  informationTypes  InformationType[]
  stakeholders      Stakeholder[]
  meetings          Meeting[]
  risks             Risk[]
  riskCategories    RiskCategory[]
  suppliers         Supplier[]
  products          Product[]
  demandData        DemandData[]
  reportCalendars   ReportCalendar[]
  interestMatrixRows InterestMatrixRow[]
  asisMemos         AsisMemo[]
  tobeVisions       TobeVision[]
  tobeRoadmaps      TobeRoadmap[]
  analysisParetoRows      AnalysisParetoRow[]
  analysisSensitivityRows AnalysisSensitivityRow[]
  analysisGapRows         AnalysisGapRow[]
  analysisLeakRows        AnalysisLeakRow[]
  gapLedgers              GapLedger[]
  roadmapPhases           RoadmapPhase[]
  charter                 ProjectCharter?
  changeRequests          ChangeRequest[]
  lessons                 LessonLearned[]
  adoptionStatuses        AdoptionStatus[]
  dataObjects             DataObject[]
  dataObjectRelations     DataObjectRelation[]
  dataObjectAnnotations   DataObjectAnnotation[]
  kpis                    Kpi[]
  members                 ProjectMember[]
  backgroundJobs          BackgroundJob[]
  webhooks                Webhook[]
  trackerConnections      IssueTrackerConnection[]
  ingestionBatches        IngestionBatch[]
  knowledgeDocuments      KnowledgeDocument[]
  knowledgeNodes          KnowledgeNode[]
  knowledgeRelations      KnowledgeRelation[]
  driveConnections        DriveConnection[]
  llmUsageLogs            LlmUsageLog[]
  overviewMatrices        OverviewMatrix[]
  imageBoards             ImageBoard[]
  diagramElements         DiagramElement[]
  nodeAttachments         NodeAttachment[]
  knowledgeNodeLinks      KnowledgeNodeLink[]

  @@unique([organizationId, slug])
  @@map("projects")
}

// ===========================================
// ロール
// ===========================================

model Role {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  // 所属システム / サブ領域（共通マスタ基盤。任意）
  systemId     String?  @map("system_id")
  subProjectId String?  @map("sub_project_id")
  name        String
  type        RoleType @default(HUMAN)
  description String?
  color       String?
  order       Int      @default(0)
  laneHeight  Int      @default(120) @map("lane_height") // スイムレーンの高さ
  responsibility String? @db.Text
  decisionScope  String? @map("decision_scope") @db.Text
  kpi            String? @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  system       System?       @relation(fields: [systemId], references: [id], onDelete: SetNull)
  subProject   SubProject?   @relation(fields: [subProjectId], references: [id], onDelete: SetNull)
  flowNodes    FlowNode[]
  crudMappings CrudMapping[]
  apiRolePermissions    ApiRolePermission[]
  statusRolePermissions StatusRolePermission[]
  assignedTasks         Task[]                 @relation("RoleAssignedTasks")
  ownedKpis             Kpi[]

  @@unique([projectId, name])
  @@map("roles")
}

enum RoleType {
  HUMAN
  SYSTEM
  OTHER
}

// ===========================================
// データカタログ
// ===========================================

model Table {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  // 紐づく情報種別マスタ（共通マスタ基盤。任意）
  informationTypeId String? @map("information_type_id")
  // 所属オブジェクト（DFDデータストア＝オブジェクト関係性マップの共通マスタ。任意）
  dataObjectId String? @map("data_object_id")
  name        String
  displayName String?  @map("display_name")
  description String?
  tags        String[] @default([])
  // ER図キャンバス上の位置
  erPositionX Float    @default(0) @map("er_position_x")
  erPositionY Float    @default(0) @map("er_position_y")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  informationType InformationType? @relation(fields: [informationTypeId], references: [id], onDelete: SetNull)
  dataObject DataObject? @relation(fields: [dataObjectId], references: [id], onDelete: SetNull)
  columns  Column[]
  statuses TableStatus[]

  @@unique([projectId, name])
  @@map("tables")
}

model Column {
  id               String         @id @default(uuid())
  tableId          String         @map("table_id")
  name             String
  displayName      String?        @map("display_name")
  dataType         ColumnDataType @default(STRING)
  description      String?
  isPrimaryKey     Boolean        @default(false) @map("is_primary_key")
  isForeignKey     Boolean        @default(false) @map("is_foreign_key")
  isNullable       Boolean        @default(true) @map("is_nullable")
  isUnique         Boolean        @default(false) @map("is_unique")
  defaultValue     String?        @map("default_value")
  foreignKeyTable  String?        @map("foreign_key_table")
  foreignKeyColumn String?        @map("foreign_key_column")
  order            Int            @default(0)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  table            Table             @relation(fields: [tableId], references: [id], onDelete: Cascade)
  crudMappings     CrudMapping[]
  interfaceColumns InterfaceColumn[]

  @@unique([tableId, name])
  @@map("columns")
}

enum ColumnDataType {
  STRING
  INTEGER
  FLOAT
  BOOLEAN
  DATE
  DATETIME
  JSON
  TEXT
  UUID
}

// ===========================================
// 業務フロー（階層構造対応）
// ===========================================

model BusinessFlow {
  id          String         @id @default(uuid())
  projectId   String         @map("project_id")
  name        String
  description String?
  version     Int            @default(1)
  // ASIS / TOBE 判別子と確信度（Ph.1仮説→Ph.2確定の昇格）
  kind        FlowKind       @default(ASIS)
  confidence  FlowConfidence @default(HYPOTHESIS)
  // 親フローへの参照（階層構造）
  parentId    String?        @map("parent_id")
  // 対応するASIS業務フローへの参照（このフローがTOBEの場合）
  asisFlowId  String?        @map("asis_flow_id")
  // 階層の深さ（ルート=0, 子=1, 孫=2...）
  depth       Int            @default(0)
  // サブプロジェクトによるグルーピング（任意）
  subProjectId String?       @map("sub_project_id")
  // フォルダによるグルーピング（任意）
  folderId    String?        @map("folder_id")
  // スイムレーンのロール別レーン高さ（手動リサイズの永続化）。{ [roleId]: height } のマップ
  laneHeights Json           @default("{}") @map("lane_heights")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  project             Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subProject          SubProject?              @relation(fields: [subProjectId], references: [id], onDelete: SetNull)
  folder              FlowFolder?              @relation(fields: [folderId], references: [id], onDelete: SetNull)
  parent              BusinessFlow?            @relation("FlowHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children            BusinessFlow[]           @relation("FlowHierarchy")
  // 対応するASIS業務フロー（このフローがTOBEの場合）と、このASISフローを参照するTOBEフロー群
  asisFlow            BusinessFlow?            @relation("FlowAsisTobe", fields: [asisFlowId], references: [id], onDelete: SetNull)
  tobeFlows           BusinessFlow[]           @relation("FlowAsisTobe")
  nodes               FlowNode[]
  edges               FlowEdge[]
  // この業務フローに紐づく業務ブロック（親フローのノード）
  parentNode          FlowNode?                @relation("NodeChildFlow")
  crudMappings        CrudMapping[]
  requirementMappings RequirementFlowMapping[]
  gapAsisItems        GapItem[]                @relation("GapAsisFlow")
  gapTobeItems        GapItem[]                @relation("GapTobeFlow")
  // 他フローのノードからこのフローへ向かう入出力リンク
  nodeLinkTargets     FlowNodeLink[]           @relation("NodeLinkTargetFlow")
  definition          FlowDefinition?
  dfd                 DfdDiagram?              @relation("FlowDfd")
  dfdNodeRefs         DfdNode[]                @relation("DfdNodeRefFlow")
  cruoaCols           CruoaCol[]
  cruoaRows           CruoaRow[]
  // Undo/Redo 用スナップショット履歴
  snapshots           FlowSnapshot[]
  // 業務フロー上の注釈（付箋・コメント）
  annotations         FlowAnnotation[]
  // この ASIS 業務フローを参照する TOBE ビジョン
  asisTobeVisions     TobeVision[]             @relation("TobeVisionAsisFlow")
  // この業務フローに紐づく添付ファイル
  attachments         Attachment[]             @relation("FlowAttachments")
  // この業務フローを対象に作成された KPI（生成の元フロー用・後方互換）
  kpis                Kpi[]                    @relation("KpiFlow")
  // この業務フローを ASIS として紐づける KPI
  kpisAsis            Kpi[]                    @relation("KpiAsisFlow")
  // この業務フローを TOBE として紐づける KPI
  kpisTobe            Kpi[]                    @relation("KpiTobeFlow")
  assignees           FlowStakeholder[]

  @@map("business_flows")
}

// ===========================================
// 業務フロー Undo/Redo スナップショット履歴
// 1スナップショット = フローの編集状態 JSON（nodes/edges）
// ===========================================

model FlowSnapshot {
  id        String   @id @default(uuid())
  flowId    String   @map("flow_id")
  seq       Int
  label     String?
  data      Json
  createdAt DateTime @default(now()) @map("created_at")

  flow BusinessFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId, seq])
  @@map("flow_snapshots")
}

// ===========================================
// 業務フロー上の注釈（付箋・コメント）
// キャンバス上の自由配置メモ。ノード/エッジには紐づかない
// ===========================================

enum FlowAnnotationKind {
  STICKY   // 付箋
  COMMENT  // コメント
  ICON     // アイコン
  SCOPE    // スコープ囲み（業務領域を点線/背景色つき矩形で囲う）
}

model FlowAnnotation {
  id        String             @id @default(uuid())
  flowId    String             @map("flow_id")
  kind      FlowAnnotationKind @default(STICKY)
  text      String             @default("") @db.Text
  positionX Float              @default(0) @map("position_x")
  positionY Float              @default(0) @map("position_y")
  // 付箋・アイコンのサイズ（手動リサイズの永続化）。null=従来固定サイズ扱い
  width     Float?             @map("width")
  height    Float?             @map("height")
  color     String?
  icon      String?            // kind=ICON のとき lucide アイコン名
  // kind=SCOPE の枠線スタイル 'dashed' | 'solid' と背景塗りの不透明度(0-1)
  borderStyle String?          @map("border_style")
  fillOpacity Float?           @map("fill_opacity")
  order     Int                @default(0)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  flow BusinessFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId])
  @@map("flow_annotations")
}

model FlowDefinition {
  id                String   @id @default(uuid())
  flowId            String   @unique @map("flow_id")
  purpose           String?  @db.Text
  owner             String?
  stakeholders      String?  @db.Text
  input             String?  @db.Text
  inputDetail       String?  @db.Text @map("input_detail")
  trigger           String?  @db.Text
  doSteps           Json     @default("[]") @map("do_steps")
  output            String?  @db.Text
  nextProcess       String?  @db.Text @map("next_process")
  exceptionHandling String?  @db.Text @map("exception_handling")
  frequency         String?
  system            String?
  tacitNotes        String?  @db.Text @map("tacit_notes")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  flow BusinessFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@map("flow_definitions")
}

// 業務ブロック（四角形・ひし形など）
model FlowNode {
  id          String       @id @default(uuid())
  flowId      String       @map("flow_id")
  type        FlowNodeType @default(PROCESS)
  label       String
  description String?
  positionX   Float        @map("position_x")
  positionY   Float        @map("position_y")
  // ノードのサイズ（手動リサイズの永続化）。null=従来固定サイズ扱い
  width       Float?       @map("width")
  height      Float?       @map("height")
  // 時系列順（構造ベース自動レイアウトのタイブレーク。layerはエッジから導出）
  order       Int          @default(0)
  roleId      String?      @map("role_id")
  // 業務ブロックが子フローを持つ場合の参照
  childFlowId String?      @unique @map("child_flow_id")
  // 処理時間・対応数・補足（metadata から実カラム化）
  processingTime String?   @map("processing_time")
  handledCount   String?   @map("handled_count")
  supplement     String?   @map("supplement")
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  flow                BusinessFlow             @relation(fields: [flowId], references: [id], onDelete: Cascade)
  role                Role?                    @relation(fields: [roleId], references: [id], onDelete: SetNull)
  // この業務ブロックの子フロー
  childFlow           BusinessFlow?            @relation("NodeChildFlow", fields: [childFlowId], references: [id], onDelete: SetNull)
  crudMappings        CrudMapping[]
  sourceEdges         FlowEdge[]               @relation("SourceNode")
  targetEdges         FlowEdge[]               @relation("TargetNode")
  requirementMappings RequirementFlowMapping[]
  gapAsisNodes        GapItem[]                @relation("GapAsisNode")
  gapTobeNodes        GapItem[]                @relation("GapTobeNode")
  // このノードが持つクロスフロー入出力リンク
  links               FlowNodeLink[]           @relation("NodeLinks")
  // 他ノードのリンクがこのノードを参照しているもの
  linkTargets         FlowNodeLink[]           @relation("NodeLinkTargetNode")
  dfdNodeRefs         DfdNode[]                @relation("DfdNodeRefNode")
  // このノードの入出力（情報種別マスタとの紐づけ）
  informationLinks    NodeInformationLink[]

  @@map("flow_nodes")
}

enum FlowNodeType {
  START
  END
  PROCESS // 四角形：処理・業務
  DECISION // ひし形：分岐
  SYSTEM_INTEGRATION
  MANUAL_OPERATION
  DATA_STORE
}

model FlowEdge {
  id           String   @id @default(uuid())
  flowId       String   @map("flow_id")
  sourceNodeId String   @map("source_node_id")
  targetNodeId String   @map("target_node_id")
  sourceHandle String?  @map("source_handle")
  targetHandle String?  @map("target_handle")
  label        String?
  condition    String?
  // この矢印上を流れるデータ（情報種別マスタとの紐づけ）
  informationTypeId String? @map("information_type_id")
  // 線の形状: 'smoothstep'(角ばり,既定) | 'bezier'(曲線) | 'straight'(直線)
  pathStyle    String?  @map("path_style")
  // ラベル文字・運ぶ情報チップの「パス上の位置」を 0〜1 の割合で保持（未設定=0.5中央）
  labelT       Float?   @map("label_t")
  infoT        Float?   @map("info_t")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  flow                 BusinessFlow          @relation(fields: [flowId], references: [id], onDelete: Cascade)
  sourceNode           FlowNode              @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode           FlowNode              @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)
  informationType      InformationType?      @relation(fields: [informationTypeId], references: [id], onDelete: SetNull)
  interfaceDefinitions InterfaceDefinition[]
  // この矢印に紐づくAPI（CRUDのAPI一覧。複数・任意）
  apiLinks             FlowEdgeApiLink[]

  @@map("flow_edges")
}

// ===========================================
// KPI（AI作成: フローのINPUT/OUTPUT・帳票から生成。SMART採点つき）
// ===========================================

enum KpiCategory {
  BUSINESS   // 業務KPI（ASIS/TOBE業務フローの改善指標）
  AI_QUALITY // AI精度KPI（導入するAI/システム自体の精度・品質指標）
}

enum KpiDirection {
  INCREASE // 増やすほど良い
  DECREASE // 減らすほど良い
  MAINTAIN // 維持
}

enum KpiFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
}

enum KpiStatus {
  DRAFT    // AI生成直後の下書き
  ACTIVE   // 採用・運用中
  ARCHIVED
}

model Kpi {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  // 業務KPI / AI精度KPI の区分
  category    KpiCategory @default(BUSINESS)
  // 対象業務フロー（任意。主に業務KPI。生成の「元フロー」用・後方互換で保持）
  flowId      String?  @map("flow_id")
  // ASIS 業務フロー（任意。1KPIにASIS/TOBEを両方紐づけ可能）
  asisFlowId  String?  @map("asis_flow_id")
  // TOBE 業務フロー（任意。1KPIにASIS/TOBEを両方紐づけ可能）
  tobeFlowId  String?  @map("tobe_flow_id")
  // 対象システム（任意。主にAI精度KPI: どのAI/システムの精度か）
  systemId    String?  @map("system_id")
  name        String
  description String?  @db.Text
  // 計算式・定義（例: 欠品率 = 欠品件数 / 発注明細数）
  definition  String?  @db.Text
  unit        String?
  baselineValue Float? @map("baseline_value")
  targetValue   Float? @map("target_value")
  currentValue  Float? @map("current_value")
  direction   KpiDirection @default(INCREASE)
  frequency   KpiFrequency @default(MONTHLY)
  // 測定方法・データソースの説明
  measurementMethod String? @map("measurement_method") @db.Text
  // 責任者ロール（任意）
  ownerRoleId String?  @map("owner_role_id")
  // SMART採点（AI採点 0-5）と講評
  smartSpecific   Int?    @map("smart_specific")
  smartMeasurable Int?    @map("smart_measurable")
  smartAchievable Int?    @map("smart_achievable")
  smartRelevant   Int?    @map("smart_relevant")
  smartTimeBound  Int?    @map("smart_time_bound")
  smartComment    String? @map("smart_comment") @db.Text
  aiGenerated Boolean   @default(false) @map("ai_generated")
  status      KpiStatus @default(DRAFT)
  order       Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  flow      BusinessFlow? @relation("KpiFlow", fields: [flowId], references: [id], onDelete: SetNull)
  asisFlow  BusinessFlow? @relation("KpiAsisFlow", fields: [asisFlowId], references: [id], onDelete: SetNull)
  tobeFlow  BusinessFlow? @relation("KpiTobeFlow", fields: [tobeFlowId], references: [id], onDelete: SetNull)
  system    System?       @relation(fields: [systemId], references: [id], onDelete: SetNull)
  ownerRole Role?         @relation(fields: [ownerRoleId], references: [id], onDelete: SetNull)
  // 測定対象の INPUT/OUTPUT（情報種別。複数）
  informationLinks KpiInformationLink[]

  @@map("kpis")
}

model KpiInformationLink {
  id                String   @id @default(uuid())
  kpiId             String   @map("kpi_id")
  informationTypeId String   @map("information_type_id")
  createdAt         DateTime @default(now()) @map("created_at")

  kpi             Kpi             @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  informationType InformationType @relation(fields: [informationTypeId], references: [id], onDelete: Cascade)

  @@unique([kpiId, informationTypeId])
  @@map("kpi_information_links")
}

// 業務フローの矢印 × API エンドポイント（多対多。システムと人を跨ぐ矢印などに紐づけ）
model FlowEdgeApiLink {
  id            String   @id @default(uuid())
  edgeId        String   @map("edge_id")
  apiEndpointId String   @map("api_endpoint_id")
  order         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")

  edge        FlowEdge    @relation(fields: [edgeId], references: [id], onDelete: Cascade)
  apiEndpoint ApiEndpoint @relation(fields: [apiEndpointId], references: [id], onDelete: Cascade)

  @@unique([edgeId, apiEndpointId])
  @@map("flow_edge_api_links")
}

// ===========================================
// フローフォルダ（業務フローの入れ子グルーピング）
// ===========================================

model FlowFolder {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  // 親フォルダ（入れ子フォルダ）
  parentId  String?  @map("parent_id")
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent        FlowFolder?    @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children      FlowFolder[]   @relation("FolderTree")
  businessFlows BusinessFlow[]

  @@map("flow_folders")
}

// ===========================================
// クロスフロー入出力リンク（ノード ⇔ 他フロー/他ノード）
// ===========================================

enum FlowLinkDirection {
  INPUT
  OUTPUT
}

model FlowNodeLink {
  id           String            @id @default(uuid())
  nodeId       String            @map("node_id")
  direction    FlowLinkDirection
  targetFlowId String            @map("target_flow_id")
  targetNodeId String?           @map("target_node_id")
  label        String?
  order        Int               @default(0)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  node       FlowNode     @relation("NodeLinks", fields: [nodeId], references: [id], onDelete: Cascade)
  targetFlow BusinessFlow @relation("NodeLinkTargetFlow", fields: [targetFlowId], references: [id], onDelete: Cascade)
  targetNode FlowNode?    @relation("NodeLinkTargetNode", fields: [targetNodeId], references: [id], onDelete: SetNull)

  @@map("flow_node_links")
}

// ===========================================
// ノード入出力 ⇔ 情報種別マスタ
// （ノードのINPUT/OUTPUTを情報種別マスタから選ぶ）
// ===========================================

model NodeInformationLink {
  id                String   @id @default(uuid())
  nodeId            String   @map("node_id")
  informationTypeId String   @map("information_type_id")
  direction         FlowLinkDirection
  order             Int      @default(0)
  createdAt         DateTime @default(now()) @map("created_at")

  node            FlowNode        @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  informationType InformationType @relation(fields: [informationTypeId], references: [id], onDelete: Cascade)

  @@map("node_information_links")
}

// ===========================================
// CRUDマッピング（カラム⇔業務紐づけ）
// ===========================================

// 各カラムに対して複数のCRUD操作を定義可能
// 例：userテーブルのemailカラムに対して
//   - C: 顧客ロールがユーザー登録フローで作成
//   - C: 管理者ロールが管理画面から手動作成
//   - U: 顧客ロールがプロフィール編集で更新
model CrudMapping {
  id          String        @id @default(uuid())
  columnId    String        @map("column_id")
  operation   CrudOperation
  roleId      String        @map("role_id")
  // 紐づく業務フロー
  flowId      String?       @map("flow_id")
  // 紐づく業務ブロック（フロー内のノード）
  flowNodeId  String?       @map("flow_node_id")
  // 操作の詳細説明（どのように作成/更新するか）
  how         String?
  condition   String?
  description String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  column              Column                   @relation(fields: [columnId], references: [id], onDelete: Cascade)
  role                Role                     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  flow                BusinessFlow?            @relation(fields: [flowId], references: [id], onDelete: SetNull)
  flowNode            FlowNode?                @relation(fields: [flowNodeId], references: [id], onDelete: SetNull)
  requirementMappings RequirementCrudMapping[]

  @@map("crud_mappings")
}

enum CrudOperation {
  CREATE
  READ
  UPDATE
  DELETE
}

// ===========================================
// IF定義（インターフェース定義）
// ===========================================

model InterfaceDefinition {
  id          String          @id @default(uuid())
  flowEdgeId  String          @map("flow_edge_id")
  name        String
  description String?
  format      InterfaceFormat @default(API)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  flowEdge FlowEdge          @relation(fields: [flowEdgeId], references: [id], onDelete: Cascade)
  columns  InterfaceColumn[]

  @@map("interface_definitions")
}

enum InterfaceFormat {
  API
  CSV
  SCREEN
  FILE
  DATABASE
  OTHER
}

model InterfaceColumn {
  id            String  @id @default(uuid())
  interfaceId   String  @map("interface_id")
  columnId      String  @map("column_id")
  isRequired    Boolean @default(false) @map("is_required")
  transformRule String? @map("transform_rule")

  interface InterfaceDefinition @relation(fields: [interfaceId], references: [id], onDelete: Cascade)
  column    Column              @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@unique([interfaceId, columnId])
  @@map("interface_columns")
}

// ===========================================
// ユーザー設定（APIキー等）
// ===========================================

model UserSetting {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  // API Keys（暗号化して保存）
  anthropicApiKey String?  @map("anthropic_api_key")
  openaiApiKey    String?  @map("openai_api_key")
  // その他の設定
  settings        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ===========================================
// 要求定義（階層構造）
// ===========================================

model Requirement {
  id           String              @id @default(uuid())
  projectId    String              @map("project_id")
  // 階層構造
  parentId     String?             @map("parent_id")
  depth        Int                 @default(0)
  order        Int                 @default(0)
  // 要求内容
  code         String? // 要求番号（例：REQ-001）
  title        String
  description  String?             @db.Text
  // 元の自然言語入力
  originalText String?             @map("original_text") @db.Text
  // 要求タイプ
  type         RequirementType     @default(FUNCTIONAL)
  priority     RequirementPriority @default(MEDIUM)
  status       RequirementStatus   @default(DRAFT)
  // メタデータ
  metadata     Json                @default("{}")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   Requirement?  @relation("RequirementHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Requirement[] @relation("RequirementHierarchy")

  // 業務フロー・CRUDとの紐付け
  flowMappings RequirementFlowMapping[]
  crudMappings RequirementCrudMapping[]

  @@map("requirements")
}

enum RequirementType {
  FUNCTIONAL // 機能要求
  NON_FUNCTIONAL // 非機能要求
  BUSINESS_RULE // ビジネスルール
  CONSTRAINT // 制約
  INTERFACE // インターフェース要求
  DATA // データ要求
}

enum RequirementPriority {
  HIGH
  MEDIUM
  LOW
}

enum RequirementStatus {
  DRAFT
  REVIEW
  APPROVED
  IMPLEMENTED
  VERIFIED
}

// 要求と業務フローの紐付け
model RequirementFlowMapping {
  id            String   @id @default(uuid())
  requirementId String   @map("requirement_id")
  flowId        String   @map("flow_id")
  flowNodeId    String?  @map("flow_node_id")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")

  requirement Requirement  @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  flow        BusinessFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowNode    FlowNode?    @relation(fields: [flowNodeId], references: [id], onDelete: SetNull)

  @@map("requirement_flow_mappings")
}

// 要求とCRUDマッピングの紐付け
model RequirementCrudMapping {
  id            String   @id @default(uuid())
  requirementId String   @map("requirement_id")
  crudMappingId String   @map("crud_mapping_id")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")

  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  crudMapping CrudMapping @relation(fields: [crudMappingId], references: [id], onDelete: Cascade)

  @@map("requirement_crud_mappings")
}

// ===========================================
// プロジェクトフェーズ（Ph.0〜Ph.7 パイプライン）
// ===========================================

model ProjectPhase {
  id        String      @id @default(uuid())
  projectId String      @map("project_id")
  kind      PhaseKind
  order     Int         @default(0)
  status    PhaseStatus @default(NOT_STARTED)
  summary   String?     @db.Text
  detail    String?     @db.Text
  metadata  Json        @default("{}")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  attachments Attachment[]

  @@unique([projectId, kind])
  @@map("project_phases")
}

enum PhaseKind {
  BACKGROUND // Ph.0 構想・背景理解
  ASIS_DATA // Ph.1 現状把握（データ）
  HEARING // Ph.2 現状把握（ヒアリング）
  ISSUE_ANALYSIS // Ph.3 課題構造化（イシューツリー）
  TOBE // Ph.4 TOBE設計
  PROPOSAL // Ph.5 提案・合意形成
  REQUIREMENTS // Ph.6 要件定義
  EXECUTION // Ph.7 推進・実行管理＋動作確認
}

enum PhaseStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  APPROVED
  DONE
}

// ===========================================
// イシューツリー（なぜ型 / 打ち手型）
// ===========================================

model IssueTree {
  id           String           @id @default(uuid())
  projectId    String           @map("project_id")
  // 旧: ツリー型（WHY/SOLUTION）。互換のため残置。新規は pattern を使う。
  type         IssueTreeType
  // 新: ツリーパターン（作成時に選ぶテンプレ）
  pattern      IssueTreePattern @default(ISSUE_POINT)
  name         String
  rootQuestion String?          @map("root_question") @db.Text
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  project  Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nodes    IssueNode[]
  // この打ち手ツリーが改善対象とする GAP（SOLUTION型 ⇔ GapItem）
  gapItems GapItem[]

  @@map("issue_trees")
}

enum IssueTreeType {
  WHY // なぜ型（調査・原因究明）
  SOLUTION // 打ち手型（How・MECEアクション）
}

enum IssueTreePattern {
  ISSUE_POINT // イシューツリー（論点・調査）
  WHY // Whyツリー（原因究明）
  WHAT // Whatツリー（対象分割）
  HOW // Howツリー（打ち手・発散）
  MECE_ACTION // MECEアクションツリー（打ち手・網羅）
  KPI // KPIツリー
}

model IssueNode {
  id              String             @id @default(uuid())
  treeId          String             @map("tree_id")
  parentId        String?            @map("parent_id")
  depth           Int                @default(0)
  order           Int                @default(0)
  label           String             @db.Text
  kind            IssueNodeKind      @default(ISSUE)
  verification    NodeVerification   @default(NA)
  recommendation  NodeRecommendation @default(NA)
  evidence        String?            @db.Text
  // SOLUTION型の根本原因ノードが参照する WHY型の確定ノード（任意）
  rootCauseNodeId String?            @map("root_cause_node_id")
  metadata        Json               @default("{}")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  tree     IssueTree   @relation(fields: [treeId], references: [id], onDelete: Cascade)
  parent   IssueNode?  @relation("IssueNodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children IssueNode[] @relation("IssueNodeHierarchy")
  tasks    Task[]

  @@map("issue_nodes")
}

enum NodeVerification {
  CONFIRMED // ○ 裏付けあり/確定
  REJECTED // × 否定/不支持
  UNKNOWN // △ データで言えない
  NEEDS_HEARING // 【未確認/要ヒアリング】
  NA // 検証対象外（SOLUTION型など）
}

enum NodeRecommendation {
  ADOPT // 採用
  HOLD // 保留
  REJECT // 不採用
  NA
}

// ===========================================
// GAP（ASIS と TOBE の差分＝本当の課題）
// ===========================================

model GapItem {
  id              String      @id @default(uuid())
  projectId       String      @map("project_id")
  phaseId         String?     @map("phase_id")
  businessArea    String      @map("business_area")
  asisDescription String?     @map("asis_description") @db.Text
  tobeDescription String?     @map("tobe_description") @db.Text
  gapDescription  String?     @map("gap_description") @db.Text
  priority        GapPriority @default(MEDIUM)
  status          GapStatus   @default(OPEN)
  ownerName       String?     @map("owner_name")
  order           Int         @default(0)
  // スコープ外フラグ（今回の取り組み範囲から除外した GAP）
  outOfScope      Boolean     @default(false) @map("out_of_scope")
  // ASIS / TOBE フロー・ノードへの差分マッピング（全て任意）
  asisFlowId      String?     @map("asis_flow_id")
  asisNodeId      String?     @map("asis_node_id")
  tobeFlowId      String?     @map("tobe_flow_id")
  tobeNodeId      String?     @map("tobe_node_id")
  // この GAP を改善する打ち手ツリー（SOLUTION型 IssueTree, 任意）
  issueTreeId     String?     @map("issue_tree_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asisFlow  BusinessFlow? @relation("GapAsisFlow", fields: [asisFlowId], references: [id], onDelete: SetNull)
  tobeFlow  BusinessFlow? @relation("GapTobeFlow", fields: [tobeFlowId], references: [id], onDelete: SetNull)
  asisNode  FlowNode?     @relation("GapAsisNode", fields: [asisNodeId], references: [id], onDelete: SetNull)
  tobeNode  FlowNode?     @relation("GapTobeNode", fields: [tobeNodeId], references: [id], onDelete: SetNull)
  issueTree IssueTree?    @relation(fields: [issueTreeId], references: [id], onDelete: SetNull)
  ledger    GapLedger?

  @@map("gap_items")
}

enum GapPriority {
  HIGH
  MEDIUM
  LOW
}

enum GapStatus {
  OPEN
  RESOLVED
}

// ===========================================
// 公開APIキー（/api/v1 + MCP用）
// ===========================================

model ApiKey {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  projectId  String?   @map("project_id")
  name       String
  keyHash    String    @unique @map("key_hash")
  keyPrefix  String    @map("key_prefix")
  scopes     String[]  @default([])
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// BusinessFlow 用の判別子
enum FlowKind {
  ASIS
  TOBE
}

enum FlowConfidence {
  HYPOTHESIS
  CONFIRMED
}

// ===========================================
// GitHub連携 + コードからのAI抽出（背景エージェント）
// ===========================================

model GithubConnection {
  id                  String    @id @default(uuid())
  projectId           String    @map("project_id")
  repoFullName        String    @map("repo_full_name") // owner/repo
  branch              String    @default("main")
  tokenEnc            String    @map("token_enc") // AES-256-GCM 暗号化PAT
  autoSync            Boolean   @default(false) @map("auto_sync")
  syncIntervalMinutes Int       @default(30) @map("sync_interval_minutes")
  lastSyncedSha       String?   @map("last_synced_sha")
  lastSyncedAt        DateTime? @map("last_synced_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs    SyncRun[]

  @@unique([projectId, repoFullName])
  @@map("github_connections")
}

model SyncRun {
  id           String        @id @default(uuid())
  connectionId String        @map("connection_id")
  status       SyncRunStatus @default(PENDING)
  trigger      SyncTrigger   @default(MANUAL)
  commitSha    String?       @map("commit_sha")
  summary      Json          @default("{}") // {apis,tables,statuses,roles} 件数
  error        String?       @db.Text
  log          String?       @db.Text
  startedAt    DateTime      @default(now()) @map("started_at")
  finishedAt   DateTime?     @map("finished_at")

  connection GithubConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@map("sync_runs")
}

enum SyncRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum SyncTrigger {
  MANUAL
  AUTO
}

model ApiEndpoint {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  method     String // GET/POST/PUT/DELETE/...
  path       String
  summary    String?
  sourceFile String?  @map("source_file")
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rolePermissions ApiRolePermission[]
  flowEdgeLinks   FlowEdgeApiLink[]

  @@unique([projectId, method, path])
  @@map("api_endpoints")
}

model ApiRolePermission {
  id            String  @id @default(uuid())
  apiEndpointId String  @map("api_endpoint_id")
  roleId        String  @map("role_id")
  allowed       Boolean @default(true)
  note          String?

  apiEndpoint ApiEndpoint @relation(fields: [apiEndpointId], references: [id], onDelete: Cascade)
  role        Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([apiEndpointId, roleId])
  @@map("api_role_permissions")
}

model TableStatus {
  id        String   @id @default(uuid())
  tableId   String   @map("table_id")
  value     String // 例: 下書き / 申請中 / 承認済み
  label     String?
  color     String?
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  table           Table                  @relation(fields: [tableId], references: [id], onDelete: Cascade)
  rolePermissions StatusRolePermission[]

  @@unique([tableId, value])
  @@map("table_statuses")
}

model StatusRolePermission {
  id            String   @id @default(uuid())
  tableStatusId String   @map("table_status_id")
  roleId        String   @map("role_id")
  operations    String[] @default([]) // 許可操作: C/R/U/D/承認 等
  note          String?

  tableStatus TableStatus @relation(fields: [tableStatusId], references: [id], onDelete: Cascade)
  role        Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([tableStatusId, roleId])
  @@map("status_role_permissions")
}

// ===========================================
// サブプロジェクト / 添付ファイル
// ===========================================

model SubProject {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  // 親サブ領域（領域→サブ領域の入れ子。任意）
  parentId    String?  @map("parent_id")
  name        String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent        SubProject?  @relation("SubProjectTree", fields: [parentId], references: [id], onDelete: Cascade)
  children      SubProject[] @relation("SubProjectTree")
  businessFlows BusinessFlow[]
  roles            Role[]
  systems          System[]
  constraints      Constraint[]
  informationTypes InformationType[]
  tobeVisions      TobeVision[]
  tobeRoadmaps     TobeRoadmap[]
  risks            Risk[]
  stakeholderAssignments StakeholderSubProject[]
  lessons          LessonLearned[]
  meetingLinks     MeetingSubProject[]
  dataObjects            DataObject[]
  dataObjectAnnotations  DataObjectAnnotation[]

  @@map("sub_projects")
}

// ===========================================
// 共通マスタ基盤：システム / 制約
// ===========================================

// システム種別（周辺システム / 今回作る対象システム）
enum SystemKind {
  PERIPHERAL // 周辺システム
  TARGET     // 今回作る対象システム
}

model System {
  id           String     @id @default(uuid())
  projectId    String     @map("project_id")
  subProjectId String?    @map("sub_project_id")
  name         String
  kind         SystemKind @default(PERIPHERAL)
  description  String?    @db.Text
  order        Int        @default(0)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subProject       SubProject?      @relation(fields: [subProjectId], references: [id], onDelete: SetNull)
  roles            Role[]
  adoptionStatuses AdoptionStatus[]
  kpis             Kpi[]

  @@map("systems")
}

model Constraint {
  id           String   @id @default(uuid())
  projectId    String   @map("project_id")
  subProjectId String?  @map("sub_project_id")
  title        String
  description  String?  @db.Text
  category     String?
  kind         String?  @default("CONSTRAINT") // CONSTRAINT=制約 / ASSUMPTION=前提条件
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subProject SubProject? @relation(fields: [subProjectId], references: [id], onDelete: SetNull)

  @@map("constraints")
}

model Attachment {
  id        String         @id @default(uuid())
  projectId String         @map("project_id")
  phaseId   String?        @map("phase_id")
  taskId    String?        @map("task_id")
  kind      AttachmentKind @default(FILE)
  filename  String
  // 表示名（編集可能。null=filename を表示）
  displayName String?      @map("display_name")
  // フォルダ分け（自由入力のフォルダ名。null=未分類）
  folder    String?
  mimeType  String         @map("mime_type")
  url       String // 配信パス（/uploads/...）
  size      Int            @default(0)
  pageRange String?        @map("page_range") // PDFのページ指定 例: "1-3,5"
  caption   String?
  order     Int            @default(0)
  data      Bytes? // ファイル本体。serverless では DB 保存に使用。既存ローカル行は null=ディスク参照のまま
  // Vercel Blob 公開URL。client直アップロード由来はこれを持ち data=null。取得/配信は data→blobUrl→url の順。
  blobUrl   String?        @map("blob_url")
  createdAt DateTime       @default(now()) @map("created_at")

  informationTypeId String?  @map("information_type_id")
  flowId            String?  @map("flow_id")

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase   ProjectPhase? @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  task    Task?         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  informationType InformationType? @relation(fields: [informationTypeId], references: [id], onDelete: Cascade)
  flow    BusinessFlow? @relation("FlowAttachments", fields: [flowId], references: [id], onDelete: Cascade)
  diagramElements DiagramElement[]
  nodeAttachments NodeAttachment[]

  @@map("attachments")
}

enum AttachmentKind {
  IMAGE
  PDF
  FILE
}

enum IssueNodeKind {
  ISSUE
  CAUSE
  COUNTERMEASURE
  POINT
  HYPOTHESIS
  VERIFICATION
  RESULT
  ELEMENT
  OPTION
  ACTION
  METRIC
}

// ===========================================
// DB直結（データカタログのスキーマ取り込み元・複数可）
// ===========================================

model DatabaseConnection {
  id                 String    @id @default(uuid())
  projectId          String    @map("project_id")
  name               String
  dialect            String    @default("postgres") // postgres / mysql / ...
  connStringEnc      String    @map("conn_string_enc") // AES-256-GCM 暗号化した接続文字列
  lastIntrospectedAt DateTime? @map("last_introspected_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("database_connections")
}

// ===========================================
// 記録シート（教材の配布物テンプレ＝表形式の記録）
// ===========================================

// ===========================================
// タスク（Backlog相当：親タスク・依存関係対応）
// ===========================================

enum TaskStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum TaskIssueType {
  EPIC
  STORY
  TASK
  SUBTASK
  BUG
  OTHER
}

model Task {
  id             String       @id @default(uuid())
  projectId      String       @map("project_id")
  // 親タスク（subtask / 親タスク）
  parentId       String?      @map("parent_id")
  // 外部トラッカー(Backlog/Jira)からの移行・同期で冪等 upsert するための由来キー。
  // 例: "BACKLOG:IPLOT-12" / "JIRA:ABC-34"。手動作成タスクは null。
  // (projectId, sourceKey) で一意にし、再 import 時に重複作成せず更新する。
  sourceKey      String?      @map("source_key")
  title          String
  description    String?      @db.Text
  status         TaskStatus   @default(OPEN)
  priority       TaskPriority @default(MEDIUM)
  // アジャイル拡張: イシュー種別（EPIC/STORY/TASK/SUBTASK/BUG/OTHER）
  issueType      TaskIssueType @default(TASK) @map("issue_type")
  // issueType=EPIC の Task を指す自己FK（親子サブタスクの parentId とは別系統）
  epicId         String?      @map("epic_id")
  // ストーリーポイント（見積もり）
  storyPoints    Float?       @map("story_points")
  // スプリント識別子（任意の文字列）
  sprint         String?
  assigneeName   String?      @map("assignee_name")
  assigneeRoleId String?      @map("assignee_role_id")
  // イシューツリーのノードへの紐付け（ISSUE/CAUSE/COUNTERMEASURE）。任意。
  issueNodeId    String?      @map("issue_node_id")
  // リスク対応タスクの紐付け（任意）
  riskId         String?      @map("risk_id")
  startDate      DateTime?    @map("start_date")
  dueDate        DateTime?    @map("due_date")
  progress       Int          @default(0)
  estimatedHours Float?       @map("estimated_hours")
  actualHours    Float?       @map("actual_hours")
  milestone      String?
  category       String?
  order          Int          @default(0)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent       Task?            @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children     Task[]           @relation("TaskHierarchy")
  // アジャイル拡張: epic への自己FK（TaskHierarchy とは別名 TaskEpic で衝突回避）
  epic         Task?            @relation("TaskEpic", fields: [epicId], references: [id], onDelete: SetNull)
  epicChildren Task[]           @relation("TaskEpic")
  assigneeRole Role?            @relation("RoleAssignedTasks", fields: [assigneeRoleId], references: [id], onDelete: SetNull)
  issueNode    IssueNode?       @relation(fields: [issueNodeId], references: [id], onDelete: SetNull)
  risk         Risk?            @relation(fields: [riskId], references: [id], onDelete: SetNull)
  // この依存関係でこのタスクが後続側（先行タスクへの参照を持つ）
  predecessors TaskDependency[] @relation("DepSuccessor")
  // この依存関係でこのタスクが先行側（後続タスクから参照される）
  successors   TaskDependency[] @relation("DepPredecessor")
  comments     TaskComment[]
  attachments  Attachment[]

  // 外部トラッカー由来キーでの冪等 upsert 用（同一プロジェクト内で一意）。
  @@unique([projectId, sourceKey], name: "projectId_sourceKey")
  @@map("tasks")
}

model TaskComment {
  id           String   @id @default(uuid())
  taskId       String   @map("task_id")
  authorUserId String?  @map("author_user_id")
  authorName   String?  @map("author_name")
  body         String   @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_comments")
}

model TaskDependency {
  id            String   @id @default(uuid())
  predecessorId String   @map("predecessor_id")
  successorId   String   @map("successor_id")
  createdAt     DateTime @default(now()) @map("created_at")

  predecessor Task @relation("DepPredecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  successor   Task @relation("DepSuccessor", fields: [successorId], references: [id], onDelete: Cascade)

  @@unique([predecessorId, successorId])
  @@map("task_dependencies")
}

// ===========================================
// DFD（データフロー図）
// ===========================================

enum DfdNodeKind {
  FUNCTION
  EXTERNAL_ENTITY
  DATA_STORE
}

model DfdDiagram {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  flowId      String?  @unique @map("flow_id")
  title       String?
  docId       String?  @map("doc_id")
  authorName  String?  @map("author_name")
  approverName String? @map("approver_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  flow    BusinessFlow? @relation("FlowDfd", fields: [flowId], references: [id], onDelete: Cascade)
  nodes       DfdNode[]
  flows       DfdFlow[]
  annotations DfdAnnotation[]

  @@unique([projectId, flowId])
  @@map("dfd_diagrams")
}

// DFD キャンバス上の注釈（付箋・メモ。業務フローの FlowAnnotation と同じ概念）
model DfdAnnotation {
  id        String             @id @default(uuid())
  diagramId String             @map("diagram_id")
  kind      FlowAnnotationKind @default(STICKY)
  text      String             @default("") @db.Text
  positionX Float              @default(0) @map("position_x")
  positionY Float              @default(0) @map("position_y")
  width     Float?             @map("width")
  height    Float?             @map("height")
  color     String?
  icon      String?
  borderStyle String?          @map("border_style")
  fillOpacity Float?           @map("fill_opacity")
  order     Int                @default(0)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  diagram DfdDiagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)

  @@index([diagramId])
  @@map("dfd_annotations")
}

model DfdNode {
  id         String      @id @default(uuid())
  diagramId  String      @map("diagram_id")
  kind       DfdNodeKind
  label      String
  number     String?
  refFlowId  String?     @map("ref_flow_id")
  refNodeId  String?     @map("ref_node_id")
  // データストア（kind=DATA_STORE）の場合に紐づくオブジェクト（共通マスタ。任意）
  dataObjectId String?   @map("data_object_id")
  positionX  Float       @default(0) @map("position_x")
  positionY  Float       @default(0) @map("position_y")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  diagram    DfdDiagram    @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  refFlow    BusinessFlow? @relation("DfdNodeRefFlow", fields: [refFlowId], references: [id], onDelete: SetNull)
  refNode    FlowNode?     @relation("DfdNodeRefNode", fields: [refNodeId], references: [id], onDelete: SetNull)
  dataObject DataObject?   @relation(fields: [dataObjectId], references: [id], onDelete: SetNull)
  outFlows   DfdFlow[]     @relation("DfdFlowSource")
  inFlows    DfdFlow[]     @relation("DfdFlowTarget")

  @@map("dfd_nodes")
}

model DfdFlow {
  id           String   @id @default(uuid())
  diagramId    String   @map("diagram_id")
  sourceNodeId String   @map("source_node_id")
  targetNodeId String   @map("target_node_id")
  sourceHandle String?  @map("source_handle")
  targetHandle String?  @map("target_handle")
  dataItem     String   @map("data_item")
  informationTypeId String?  @map("information_type_id")
  // 線の形状: 'smoothstep'(角ばり,既定) | 'bezier'(曲線) | 'straight'(直線)
  pathStyle    String?  @map("path_style")
  // ラベル文字・運ぶ情報チップの「パス上の位置」を 0〜1 の割合で保持（未設定=0.5中央）
  labelT       Float?   @map("label_t")
  infoT        Float?   @map("info_t")
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  diagram    DfdDiagram  @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  sourceNode DfdNode     @relation("DfdFlowSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode DfdNode     @relation("DfdFlowTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)
  informationType InformationType? @relation(fields: [informationTypeId], references: [id], onDelete: SetNull)

  @@map("dfd_flows")
}

// ===========================================
// データオブジェクト
// （DFDデータストア＝オブジェクト関係性マップの「オブジェクト」＝ER図のグループ囲み。共通マスタ）
// ===========================================

enum RelationCardinality {
  ONE_TO_ONE
  ONE_TO_MANY
  MANY_TO_MANY
}

model DataObject {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  // 所属領域（SubProject）。スコープ囲みでの自動紐付け・紐付け画面で設定。null=未分類
  subProjectId String? @map("sub_project_id")
  name        String
  description String?  @db.Text
  color       String?
  // オブジェクト関係性マップ上の位置
  positionX   Float    @default(0) @map("position_x")
  positionY   Float    @default(0) @map("position_y")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project      Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subProject   SubProject?          @relation(fields: [subProjectId], references: [id], onDelete: SetNull)
  dfdNodes     DfdNode[]
  tables       Table[]
  outRelations DataObjectRelation[] @relation("DataObjectRelSource")
  inRelations  DataObjectRelation[] @relation("DataObjectRelTarget")

  @@unique([projectId, name])
  @@map("data_objects")
}

model DataObjectRelation {
  id             String              @id @default(uuid())
  projectId      String              @map("project_id")
  sourceObjectId String              @map("source_object_id")
  targetObjectId String              @map("target_object_id")
  cardinality    RelationCardinality @default(ONE_TO_MANY)
  label          String?
  description    String?             @db.Text
  // 線形: 'straight'（null=既定の直線） | 'bezier'（曲線）。FlowEdge/DfdFlow の pathStyle と同じ規約
  pathStyle      String?             @map("path_style")
  // 接続辺: 'top'|'right'|'bottom'|'left'、null=自動（カード中心間の交点アンカー）
  sourceHandle   String?             @map("source_handle")
  targetHandle   String?             @map("target_handle")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceObject DataObject @relation("DataObjectRelSource", fields: [sourceObjectId], references: [id], onDelete: Cascade)
  targetObject DataObject @relation("DataObjectRelTarget", fields: [targetObjectId], references: [id], onDelete: Cascade)

  @@map("data_object_relations")
}

// オブジェクト関係性マップ上の付箋/メモ（FlowAnnotation/DfdAnnotation と同型・プロジェクト単位）
model DataObjectAnnotation {
  id        String             @id @default(uuid())
  projectId String             @map("project_id")
  kind      FlowAnnotationKind @default(STICKY)
  text      String             @default("") @db.Text
  positionX Float              @default(0) @map("position_x")
  positionY Float              @default(0) @map("position_y")
  width     Float?             @map("width")
  height    Float?             @map("height")
  color     String?
  // kind=SCOPE の枠線スタイル 'dashed' | 'solid' と背景塗りの不透明度(0-1)（FlowAnnotation と同規約）
  borderStyle String?          @map("border_style")
  fillOpacity Float?           @map("fill_opacity")
  // kind=SCOPE が表す領域（SubProject）。この囲みに入ったオブジェクトを自動でこの領域に紐付ける
  subProjectId String?         @map("sub_project_id")
  // 囲み（ウィンドウ）の表示/非表示トグル
  visible    Boolean           @default(true)
  order     Int                @default(0)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subProject SubProject? @relation(fields: [subProjectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@map("data_object_annotations")
}

enum InformationCategory {
  INFORMATION
  OBJECT
  DOCUMENT
}

model InformationType {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  // 紐づくサブ領域（共通マスタ基盤。任意）
  subProjectId String? @map("sub_project_id")
  name        String
  category    InformationCategory @default(INFORMATION)
  description String?  @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subProject  SubProject?  @relation(fields: [subProjectId], references: [id], onDelete: SetNull)
  dfdFlows    DfdFlow[]
  attachments Attachment[]
  // この情報種別を入出力として参照しているノードリンク
  nodeLinks   NodeInformationLink[]
  // この情報種別を矢印上のデータとして参照しているフローエッジ
  edges       FlowEdge[]
  // この情報種別に紐づくテーブル（共通マスタ基盤）
  tables      Table[]
  // この情報種別を測定対象とする KPI
  kpiLinks    KpiInformationLink[]

  @@map("information_types")
}

// ===========================================
// ステークホルダー
// ===========================================

model Stakeholder {
  id              String   @id @default(uuid())
  projectId       String   @map("project_id")
  name            String
  affiliation     String?
  role            String?
  interest        String?  @db.Text
  concern         String?  @db.Text
  influence       String?
  support         String?
  engagement      String?  @db.Text
  reportFrequency String?  @map("report_frequency")
  contactMethod   String?  @map("contact_method")
  owner           String?
  reportLine      String?  @map("report_line")
  asisHearing     String?  @map("asis_hearing") @db.Text
  tobeSparring    String?  @map("tobe_sparring") @db.Text
  note            String?  @db.Text
  side            String?  @default("INTERNAL") // INTERNAL=内部(自社) / EXTERNAL=外部(お客様・パートナー)
  order           Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project               Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  meetings              MeetingStakeholder[]
  reportCalendars       ReportCalendar[]
  ownedMeetings         Meeting[]               @relation("MeetingOwner")
  ownedRisks            Risk[]                  @relation("RiskOwner")
  subProjectAssignments StakeholderSubProject[]
  approvedCharters      ProjectCharter[]        @relation("CharterApprover")
  sponsoredCharters     ProjectCharter[]        @relation("CharterSponsor")
  approvedChangeRequests ChangeRequest[]        @relation("ChangeApprover")
  adoptionStatuses      AdoptionStatus[]
  flowAssignments       FlowStakeholder[]

  @@map("stakeholders")
}

// ===========================================
// ステークホルダー ↔ サブプロジェクト（多対多 + RACI）
// ===========================================

model StakeholderSubProject {
  id            String   @id @default(uuid())
  stakeholderId String   @map("stakeholder_id")
  subProjectId  String   @map("sub_project_id")
  raci          String?  @default("R") // R=実行責任 / A=説明責任 / C=協業 / I=報告先
  createdAt     DateTime @default(now()) @map("created_at")

  stakeholder Stakeholder @relation(fields: [stakeholderId], references: [id], onDelete: Cascade)
  subProject  SubProject  @relation(fields: [subProjectId], references: [id], onDelete: Cascade)

  @@unique([stakeholderId, subProjectId])
  @@map("stakeholder_sub_projects")
}

// ===========================================
// 会議体
// ===========================================

model Meeting {
  id                String   @id @default(uuid())
  projectId         String   @map("project_id")
  name              String
  purpose           String?  @db.Text
  frequency         String?
  dayTime           String?  @map("day_time")
  requiredAttendees String?  @map("required_attendees") @db.Text
  optionalAttendees String?  @map("optional_attendees") @db.Text
  agendaTemplate    String?  @map("agenda_template") @db.Text
  preMaterials      String?  @map("pre_materials") @db.Text
  minutesOwner      String?  @map("minutes_owner")
  decisionMaker     String?  @map("decision_maker")
  format            String? // 対面 / オンライン / ハイブリッド（自由文字列）
  durationMinutes   Int?     @map("duration_minutes") // 所要時間（分）
  locationUrl       String?  @map("location_url") // 場所 or 会議URL
  ownerStakeholderId String? @map("owner_stakeholder_id") // 主催/ファシリテーター
  status            String?  @default("ACTIVE") // ACTIVE=開催中 / SUSPENDED=休止
  goal              String?  @db.Text // この会議のゴール/アウトプット
  note              String?  @db.Text
  order             Int      @default(0)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner           Stakeholder?         @relation("MeetingOwner", fields: [ownerStakeholderId], references: [id], onDelete: SetNull)
  stakeholders    MeetingStakeholder[]
  reportCalendars ReportCalendar[]
  risks           Risk[]
  subProjects     MeetingSubProject[]

  @@map("meetings")
}

// ===========================================
// 会議体 ↔ ステークホルダー（多対多）
// ===========================================

model MeetingStakeholder {
  id            String   @id @default(uuid())
  meetingId     String   @map("meeting_id")
  stakeholderId String   @map("stakeholder_id")
  createdAt     DateTime @default(now()) @map("created_at")

  meeting     Meeting     @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  stakeholder Stakeholder @relation(fields: [stakeholderId], references: [id], onDelete: Cascade)

  @@unique([meetingId, stakeholderId])
  @@map("meeting_stakeholders")
}

// ===========================================
// 会議体 ↔ サブ領域（多対多）
// ===========================================

model MeetingSubProject {
  id           String   @id @default(uuid())
  meetingId    String   @map("meeting_id")
  subProjectId String   @map("sub_project_id")
  createdAt    DateTime @default(now()) @map("created_at")

  meeting    Meeting    @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  subProject SubProject @relation(fields: [subProjectId], references: [id], onDelete: Cascade)

  @@unique([meetingId, subProjectId])
  @@map("meeting_sub_projects")
}

// ===========================================
// リスク・ボトルネック登録簿（PMBOK準拠）
// ===========================================

// RBS（リスク・ブレークダウン・ストラクチャー）のカテゴリ
model RiskCategory {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  risks   Risk[]

  // 初期カテゴリの冪等シード（同時GET競合時の重複挿入防止）に必須
  @@unique([projectId, name])
  @@map("risk_categories")
}

model Risk {
  id             String   @id @default(uuid())
  projectId      String   @map("project_id")
  code           String? // リスクID（表示用）
  type           String? // リスク / ボトルネック
  event          String?  @db.Text // 事象内容
  causeCategory  String?  @map("cause_category") // 人 / 情報 / 決裁 / 技術 / 外部
  probability    String? // 高 / 中 / 低（旧・後方互換のため残置）
  impact         String? // 高 / 中 / 低（旧・後方互換のため残置）
  priority       String?
  countermeasure String?  @db.Text // 対応策（予防・軽減）
  needsMtg       String?  @map("needs_mtg") // 要 / 不要
  mtgDate        String?  @map("mtg_date") // MTG設定日
  deadline       String? // 期限
  owner          String?
  status         String?
  note           String?  @db.Text
  order          Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // --- PMBOK準拠の追加項目（全て optional・後方互換） ---
  categoryId         String? @map("category_id") // RBSカテゴリ
  subProjectId       String? @map("sub_project_id") // 対象サブ領域
  ownerStakeholderId String? @map("owner_stakeholder_id") // リスクオーナー
  reviewMeetingId    String? @map("review_meeting_id") // レビュー会議体
  probabilityScore   Int?    @map("probability_score") // 発生確率 1-5
  impactScore        Int?    @map("impact_score") // 影響度 1-5
  riskType           String? @default("THREAT") @map("risk_type") // THREAT / OPPORTUNITY
  strategy           String? // 回避 / 転嫁 / 軽減 / 受容 / 活用 / 共有 / 強化
  responsePlan       String? @map("response_plan") @db.Text // 対応計画
  contingencyPlan    String? @map("contingency_plan") @db.Text // コンティンジェンシー計画
  trigger            String? @db.Text // トリガー条件
  lifecycle          String? @default("IDENTIFIED") // IDENTIFIED / ANALYZED / RESPONDING / MONITORING / OCCURRED / CLOSED

  project          Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category         RiskCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subProject       SubProject?   @relation(fields: [subProjectId], references: [id], onDelete: SetNull)
  ownerStakeholder Stakeholder?  @relation("RiskOwner", fields: [ownerStakeholderId], references: [id], onDelete: SetNull)
  reviewMeeting    Meeting?      @relation(fields: [reviewMeetingId], references: [id], onDelete: SetNull)
  tasks            Task[]

  @@map("risks")
}

// ===========================================
// 仕入先マスタ
// ===========================================

model Supplier {
  id           String   @id @default(uuid())
  projectId    String   @map("project_id")
  code         String? // 仕入先コード
  name         String // 仕入先名
  salesRep     String?  @map("sales_rep") // 担当営業
  tel          String? // 電話番号
  email        String? // メールアドレス
  leadTimeDays Int?     @map("lead_time_days") // リードタイム（日）
  note         String?  @db.Text // 備考
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  products Product[]

  @@map("suppliers")
}

// ===========================================
// 商品マスタ（仕入先・最小ロット・単価）
// ===========================================

model Product {
  id           String   @id @default(uuid())
  projectId    String   @map("project_id")
  code         String? // 商品コード
  name         String // 商品名
  supplierId   String?  @map("supplier_id") // 仕入先FK
  supplierName String?  @map("supplier_name") // 仕入先（フリーテキストfallback）
  minLot       Int?     @map("min_lot") // 最小ロット（個）
  unitPrice    Int?     @map("unit_price") // 単価（円）
  note         String?  @db.Text // 備考
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@map("products")
}

// ===========================================
// 過去需要データ（商品×期間ごとに1行）
// ===========================================

model DemandData {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  productName String?  @map("product_name") // 商品
  period      String? // 月 / 年月
  quantity    Int? // 需要数
  note        String?  @db.Text // 備考
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("demand_data")
}

// ===========================================
// 報告・連絡カレンダー
// ===========================================

model ReportCalendar {
  id            String   @id @default(uuid())
  projectId     String   @map("project_id")
  stakeholderId String?  @map("stakeholder_id") // 報告対象（誰に）FK
  reportTo      String?  @map("report_to") // 報告対象（フリーテキストfallback）
  meetingId     String?  @map("meeting_id") // 関連会議FK
  reportContent String?  @map("report_content") @db.Text // 報告内容（何を）
  frequency     String? // 頻度
  dayTime       String?  @map("day_time") // 曜日・時刻
  format        String? // 形式
  medium        String? // 媒体
  drafter       String? // 起票担当
  approver      String? // 承認者
  templateRef   String?  @map("template_ref") // テンプレ・参考
  note          String?  @db.Text // 備考
  order         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stakeholder Stakeholder? @relation(fields: [stakeholderId], references: [id], onDelete: SetNull)
  meeting     Meeting?     @relation(fields: [meetingId], references: [id], onDelete: SetNull)

  @@map("report_calendars")
}

// ===========================================
// 関心ごとマトリクス（フェーズ×ロール）
// 1フェーズ1行のフラットな実テーブル（視点は固定カラム）
// ===========================================

model InterestMatrixRow {
  id           String   @id @default(uuid())
  projectId    String   @map("project_id")
  phase        String? // フェーズ
  duration     String? // 期間目安
  mainMeetings String?  @map("main_meetings") // 主要ミーティング体
  fieldStaff   String?  @map("field_staff") @db.Text // 現場（実務担当）
  clientPm     String?  @map("client_pm") @db.Text // 先方プロマネ
  executive    String?  @db.Text // 役員（経営層）
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("interest_matrix_rows")
}

// ===========================================
// ASIS メモ（現状把握）
// ===========================================

model AsisMemo {
  id           String   @id @default(uuid())
  projectId    String   @map("project_id")
  topic        String? // テーマ
  currentState String?  @map("current_state") // 現状
  pain         String? // 痛み・課題
  restriction  String? // 制約
  note         String?  @db.Text // 備考
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("asis_memos")
}

// ===========================================
// TOBE ビジョン（あるべき姿）
// ===========================================

model TobeVision {
  id             String   @id @default(uuid())
  projectId      String   @map("project_id")
  // サブ領域への紐づけ（データ連携。任意。既存 area は後方互換のため残置）
  subProjectId   String?  @map("sub_project_id")
  // 対応する ASIS 業務フローへの紐づけ（データ連携。任意）
  asisFlowId     String?  @map("asis_flow_id")
  area           String? // 領域
  vision         String?  @db.Text // ビジョン・あるべき姿
  countermeasure String?  @db.Text // 施策・対応
  effect         String? // 効果
  order          Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subProject SubProject?   @relation(fields: [subProjectId], references: [id], onDelete: SetNull)
  // 対応する ASIS 業務フロー
  asisFlow   BusinessFlow? @relation("TobeVisionAsisFlow", fields: [asisFlowId], references: [id], onDelete: SetNull)
  // このビジョンに紐づくロードマップ施策
  roadmaps   TobeRoadmap[]

  @@map("tobe_visions")
}

// ===========================================
// TOBE ロードマップ（フェーズ別施策）
// ===========================================

model TobeRoadmap {
  id           String   @id @default(uuid())
  projectId    String   @map("project_id")
  // サブ領域への紐づけ（データ連携。任意）
  subProjectId String?  @map("sub_project_id")
  // 元になった TOBE ビジョンへの紐づけ（データ連携。任意）
  tobeVisionId String?  @map("tobe_vision_id")
  phase        String? // フェーズ
  measure      String?  @db.Text // 施策
  roi          String? // ROI
  cost         String? // コスト
  payback      String? // 回収期間
  scope        String? // 範囲
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subProject SubProject? @relation(fields: [subProjectId], references: [id], onDelete: SetNull)
  tobeVision TobeVision? @relation(fields: [tobeVisionId], references: [id], onDelete: SetNull)

  @@map("tobe_roadmaps")
}

// ===========================================
// GAP分析ツール（パレート / 感度 / ギャップ / 漏れ）
// 自由記述の RecordSheet 相当を実テーブル化（全フリーテキスト）
// ===========================================

// パレート分析（80:20）
model AnalysisParetoRow {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  code      String?
  count     String?
  amount    String?
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("analysis_pareto_rows")
}

// 感度分析（効きどころ）
model AnalysisSensitivityRow {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  measure    String?
  stars      String?
  difficulty String?
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("analysis_sensitivity_rows")
}

// ギャップ分析（自社 vs ベンチマーク）
model AnalysisGapRow {
  id           String   @id @default(uuid())
  projectId    String   @map("project_id")
  metric       String?
  self         String?
  benchmark    String?
  factor       String?
  contribution String?
  hasAction    String?  @map("has_action")
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("analysis_gap_rows")
}

// 漏れ分析（ファネル通過）
model AnalysisLeakRow {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  stage      String?
  passCount  String?  @map("pass_count")
  hypothesis String?
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("analysis_leak_rows")
}

// ===========================================
// GAP台帳オーバーレイ（gap-ledger-meta + gap-roadmap を統合）
// GAP item ごとの追加メタ（インパクト/難易度/フェーズ/補完問い）
// ===========================================

model GapLedger {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  gapId      String   @unique @map("gap_id")
  impact     String?
  difficulty String?
  phase      String?
  toComplete String?  @map("to_complete")
  // ロードマップ（roadmap ページ）用の追加項目。phase 同様 GapItem に対する 1:1 オーバーレイ。
  target     String?
  note       String?
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  gap     GapItem @relation(fields: [gapId], references: [id], onDelete: Cascade)

  @@map("gap_ledgers")
}

// ロードマップのフェーズ（列）マスタ。プロジェクトごとに追加・並べ替え可能。
model RoadmapPhase {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  name      String
  // 旧固定3フェーズとの互換キー（'Q'|'P2'|'P3'）。GapLedger.phase は legacyKey ?? name を保存する。
  legacyKey String?  @map("legacy_key")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("roadmap_phases")
}

// ===========================================
// CRUOA 情報の地図（業務フロー単位の動的マトリクス）
// 列 / 行 / セルを実テーブル化（replace-all）
// ===========================================

model CruoaCol {
  id        String   @id @default(uuid())
  flowId    String   @map("flow_id")
  label     String?
  roleId    String?  @map("role_id")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  flow BusinessFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@map("cruoa_cols")
}

model CruoaRow {
  id        String   @id @default(uuid())
  flowId    String   @map("flow_id")
  info      String?
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  flow  BusinessFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  cells CruoaCell[]

  @@map("cruoa_rows")
}

model CruoaCell {
  id        String   @id @default(uuid())
  rowId     String   @map("row_id")
  colId     String   @map("col_id")
  value     String?
  createdAt DateTime @default(now()) @map("created_at")

  row CruoaRow @relation(fields: [rowId], references: [id], onDelete: Cascade)

  @@map("cruoa_cells")
}

// ===========================================
// PMBOK 補完：プロジェクト憲章 / 変更要求 / 教訓
// ===========================================

// プロジェクト憲章（プロジェクトごとに1件）
model ProjectCharter {
  id                    String   @id @default(uuid())
  projectId             String   @unique @map("project_id")
  background            String?  @db.Text
  purpose               String?  @db.Text
  successCriteria       String?  @db.Text @map("success_criteria")
  scopeIn               String?  @db.Text @map("scope_in")
  scopeOut              String?  @db.Text @map("scope_out")
  budgetNote            String?  @map("budget_note")
  approverStakeholderId String?  @map("approver_stakeholder_id")
  sponsorStakeholderId  String?  @map("sponsor_stakeholder_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  project  Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approver Stakeholder? @relation("CharterApprover", fields: [approverStakeholderId], references: [id], onDelete: SetNull)
  sponsor  Stakeholder? @relation("CharterSponsor", fields: [sponsorStakeholderId], references: [id], onDelete: SetNull)

  @@map("project_charters")
}

// 変更要求（変更管理）
model ChangeRequest {
  id                    String    @id @default(uuid())
  projectId             String    @map("project_id")
  title                 String
  reason                String?   @db.Text
  impactScope           String?   @db.Text @map("impact_scope")
  impactSchedule        String?   @map("impact_schedule")
  impactCost            String?   @map("impact_cost")
  status                String?   @default("REQUESTED") // REQUESTED / APPROVED / REJECTED / APPLIED
  approverStakeholderId String?   @map("approver_stakeholder_id")
  decidedAt             DateTime? @map("decided_at")
  note                  String?   @db.Text
  order                 Int       @default(0)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  project  Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approver Stakeholder? @relation("ChangeApprover", fields: [approverStakeholderId], references: [id], onDelete: SetNull)

  @@map("change_requests")
}

// 教訓（レッスンズラーンド）
model LessonLearned {
  id             String   @id @default(uuid())
  projectId      String   @map("project_id")
  kind           String?  @default("WENT_WELL") // WENT_WELL=うまくいった / PROBLEM=問題 / IMPROVEMENT=改善
  content        String   @db.Text
  recommendation String?  @db.Text
  subProjectId   String?  @map("sub_project_id")
  order          Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subProject SubProject? @relation(fields: [subProjectId], references: [id], onDelete: SetNull)

  @@map("lessons_learned")
}

// ===========================================
// 変更履歴（監査ログ）
// ===========================================

// 汎用の変更履歴。FKは張らない（対象が消えてもログは残す）。
model ChangeLog {
  id         String   @id @default(uuid())
  projectId  String?  @map("project_id")
  userId     String?  @map("user_id")
  userEmail  String?  @map("user_email")
  method     String // HTTPメソッド（POST/PUT/PATCH/DELETE 等）
  path       String // リクエストパス
  entity     String? // path から導出した対象種別（business-flows/tasks/risks 等）
  action     String? // CREATE / UPDATE / DELETE
  summary    String?
  // リクエストボディ（秘匿情報は [REDACTED] にマスク・サイズ上限ありの JSON 文字列）
  body       String?  @db.Text
  statusCode Int?     @map("status_code")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([projectId, createdAt])
  @@map("change_logs")
}

// ===========================================
// 導入状況（ステークホルダー × システム の定着度トラッキング）
// ===========================================

model AdoptionStatus {
  id            String    @id @default(uuid())
  projectId     String    @map("project_id")
  stakeholderId String    @map("stakeholder_id")
  // 対象システム。null = プロジェクト全体
  systemId      String?   @map("system_id")
  // NOT_STARTED=未着手 / INFORMED=説明済 / TRAINED=トレーニング済 / TRIAL=試行中 / LIVE=本稼働 / ESTABLISHED=定着
  stage         String?   @default("NOT_STARTED")
  blockers      String?   @db.Text
  nextAction    String?   @map("next_action") @db.Text
  note          String?   @db.Text
  lastContactAt DateTime? @map("last_contact_at")
  order         Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stakeholder Stakeholder @relation(fields: [stakeholderId], references: [id], onDelete: Cascade)
  system      System?     @relation(fields: [systemId], references: [id], onDelete: SetNull)

  // NOTE: Postgres は NULL 同士を distinct 扱いするため、systemId が null（全体）の
  // 行はこの複合ユニークでは重複を防げない。マイグレーションフェーズで部分ユニーク
  // インデックス (project_id, stakeholder_id) WHERE system_id IS NULL を追加予定。
  @@unique([projectId, stakeholderId, systemId])
  @@map("adoption_statuses")
}

// ===========================================
// ナレッジグラフ取り込み（バッチ文書 → 抽出 → グラフ）
// 設計: docs/superpowers/specs/2026-06-15-knowledge-graph-batch-ingestion-design.md §4
// ===========================================

// 取り込みバッチ（親）の状態
enum IngestionBatchStatus {
  PENDING
  EXPANDING
  RUNNING
  PARTIAL
  SUCCEEDED
  FAILED
  CANCELLED
}

// 取り込みファイル（子）の細かい状態
enum IngestionFileStatus {
  PENDING
  FETCHING
  EXPANDING
  PREPROCESSING
  EXTRACTING
  MERGING
  SUCCEEDED
  FAILED
  SKIPPED
}

// 取り込み元の種別
enum IngestionSourceType {
  UPLOAD
  ATTACHMENT
  DRIVE
}

// ナレッジノードの種別（自動タグ / 実体）
enum KnowledgeNodeType {
  TAG
  ENTITY
}

// 取り込みバッチ（親）。1バッチ = 複数 IngestionFile の2階層ステータス管理。
model IngestionBatch {
  id             String               @id @default(cuid())
  projectId      String
  name           String
  status         IngestionBatchStatus @default(PENDING)
  totalFiles     Int                  @default(0)
  succeededFiles Int                  @default(0)
  failedFiles    Int                  @default(0)
  pendingFiles   Int                  @default(0)
  options        Json? // {extractTags, extractEntities, extractRelations, imagingMode, model}
  createdById    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  startedAt      DateTime?
  finishedAt     DateTime?

  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  files   IngestionFile[]

  @@index([projectId])
}

// 取り込みファイル（子）。業務的な細かいステータスを保持（BackgroundJob は実行の器）。
model IngestionFile {
  id                  String              @id @default(cuid())
  batchId             String
  projectId           String
  sourceType          IngestionSourceType
  sourceRef           String? // attachmentId / driveFileId（UPLOAD は null）
  filename            String
  displayName         String?
  mimeType            String?
  size                Int?
  blobUrl             String? // 原本の保管先（Vercel Blob）
  isArchive           Boolean             @default(false) // ZIP 等のコンテナ（展開専用、グラフには載らない）
  parentFileId        String? // どのアーカイブから展開されたか（ZIP 内エントリ）
  status              IngestionFileStatus @default(PENDING)
  step                String? // 現在ステップの人間可読ラベル
  progress            Int                 @default(0)
  attempts            Int                 @default(0)
  maxAttempts         Int                 @default(4)
  error               String?             @db.Text
  extractedText       String?             @db.Text // 前処理で得たテキスト（監査/再抽出用）
  pageImageUrls       Json? // 画像化した場合の Blob URL 群
  extractionResult    Json? // Claude の生レスポンス（マージ前）
  jobId               String? // → BackgroundJob.id
  knowledgeDocumentId String? // 生成された KnowledgeDocument
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  startedAt           DateTime?
  finishedAt          DateTime?

  batch IngestionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([projectId])
  @@index([status])
}

// 文書ノード（1ファイル = 1文書ノード。再実行で置換）。
model KnowledgeDocument {
  id              String              @id @default(cuid())
  projectId       String
  ingestionFileId String?             @unique // 1ファイル=1文書ノード（再実行で置換）
  title           String
  summary         String?             @db.Text // Claude 生成の要約
  contentText     String?             @db.Text // 抽出全文（将来の検索/RAG 土台）
  sourceType      IngestionSourceType
  sourceRef       String?
  blobUrl         String? // 原本リンク
  mimeType        String?
  positionX       Float?
  positionY       Float?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  project   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mentions  KnowledgeMention[]
  relations KnowledgeRelation[] @relation("RelationSourceDoc")

  @@index([projectId])
}

// ナレッジノード（タグ / 実体）。文書横断で名寄せマージ。
model KnowledgeNode {
  id              String            @id @default(cuid())
  projectId       String
  type            KnowledgeNodeType
  entityKind      String? // PERSON/SYSTEM/ORG/CONCEPT/PRODUCT/EVENT/LOCATION/TERM/OTHER
  label           String
  normalizedLabel String // 小文字化/trim/全半角正規化 → 名寄せキー
  description     String?           @db.Text
  color           String?
  mentionCount    Int               @default(0)
  positionX       Float?
  positionY       Float?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  project      Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mentions     KnowledgeMention[]
  outRelations KnowledgeRelation[] @relation("RelationFrom")
  inRelations  KnowledgeRelation[] @relation("RelationTo")
  diagramLinks KnowledgeNodeLink[]

  @@unique([projectId, type, normalizedLabel]) // 文書横断マージ
  @@index([projectId])
}

// 文書 ↔ ノード（メンション）。出現箇所の根拠付き。
model KnowledgeMention {
  id         String   @id @default(cuid())
  projectId  String
  documentId String
  nodeId     String
  relevance  Float? // 0..1（任意）
  snippet    String?  @db.Text // 出現箇所の根拠
  createdAt  DateTime @default(now())

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  node     KnowledgeNode     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([documentId, nodeId])
  @@index([projectId])
  @@index([nodeId])
}

// ノード ↔ ノード（関係）。出所（provenance）付き。
model KnowledgeRelation {
  id               String   @id @default(cuid())
  projectId        String
  fromNodeId       String
  toNodeId         String
  label            String? // 「承認する」「依存」等
  type             String?
  confidence       Float?
  sourceDocumentId String? // どの文書が主張したか（provenance）
  createdAt        DateTime @default(now())

  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromNode       KnowledgeNode      @relation("RelationFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode         KnowledgeNode      @relation("RelationTo", fields: [toNodeId], references: [id], onDelete: Cascade)
  sourceDocument KnowledgeDocument? @relation("RelationSourceDoc", fields: [sourceDocumentId], references: [id], onDelete: SetNull)

  @@unique([projectId, fromNodeId, toNodeId, label, sourceDocumentId])
  @@index([projectId])
}

// プロジェクト単位の課金ガード設定（AI抽出 / OCR の ON/OFF・モデル・上限）。
model ProjectKnowledgeSettings {
  id                  String   @id @default(cuid())
  projectId           String   @unique
  aiExtractionEnabled Boolean  @default(true) // Claude による 実体/タグ/関係/要約 抽出（$）
  ocrEnabled          Boolean  @default(true) // 画像/スキャンPDF を vision/document で読む（$$, 画像トークン）
  defaultModel        String? // 未設定なら EXTRACTION_MODEL
  imagingMode         String   @default("auto") // auto | always | never（Office→画像化の方針）
  maxFilesPerBatch    Int      @default(200)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// Google Drive 接続（バッチ取り込みの DRIVE ソース）。
// refresh token は AES-256-GCM（既存 CryptoService / TOKEN_ENC_KEY）で暗号化保存。レスポンスでは返さない。
model DriveConnection {
  id              String   @id @default(cuid())
  projectId       String
  email           String?
  refreshTokenEnc String   @db.Text // AES-256-GCM 暗号化 refresh token
  scope           String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId])
  @@index([projectId])
}

enum LlmUsageArea {
  KNOWLEDGE_EXTRACTION
  MERMAID_FLOW
  MERMAID_OBJECT
  KPI
  REQUIREMENT
  ISSUE_SUGGEST
  CODE_EXTRACTION
  OTHER
}

model LlmUsageLog {
  id             String       @id @default(cuid())
  projectId      String       @map("project_id")
  organizationId String?      @map("organization_id")
  userId         String?      @map("user_id")
  area           LlmUsageArea
  model          String
  inputTokens    Int          @default(0) @map("input_tokens")
  outputTokens   Int          @default(0) @map("output_tokens")
  cacheReadInputTokens     Int? @map("cache_read_input_tokens")
  cacheCreationInputTokens Int? @map("cache_creation_input_tokens")
  createdAt      DateTime     @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([projectId, area])
  @@index([projectId, model])
  @@map("llm_usage_logs")
}

// ===========================================
// 俯瞰思考（汎用 N軸 俯瞰マトリクス。v1 最大3軸。CRUOA/RACI と併存）
// ===========================================
model OverviewMatrix {
  id String @id @default(uuid())
  projectId String @map("project_id")
  name String
  purpose String? @db.Text
  cellMode String @default("TEXT")        // TEXT | TAGS | SYMBOL
  tagOptions Json? @map("tag_options")    // [{key,label,color}]（TAGS/SYMBOL用）
  order Int @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  axes OverviewMatrixAxis[]
  cells OverviewMatrixCell[]
  @@index([projectId])
  @@map("overview_matrices")
}
model OverviewMatrixAxis {
  id String @id @default(uuid())
  matrixId String @map("matrix_id")
  axisIndex Int @map("axis_index")        // 0=行,1=列,2=第3軸
  name String
  side String @default("COL")             // 'ROW' | 'COL'（第3軸の結合方向）
  createdAt DateTime @default(now()) @map("created_at")
  matrix OverviewMatrix @relation(fields: [matrixId], references: [id], onDelete: Cascade)
  items OverviewMatrixAxisItem[]
  @@unique([matrixId, axisIndex])
  @@index([matrixId])
  @@map("overview_matrix_axes")
}
model OverviewMatrixAxisItem {
  id String @id @default(uuid())
  axisId String @map("axis_id")
  label String
  order Int @default(0)
  sourceType String @default("FREE") @map("source_type")  // FREE|ROLE|DATA_OBJECT|TABLE|SYSTEM|STATUS
  sourceId String? @map("source_id")
  createdAt DateTime @default(now()) @map("created_at")
  axis OverviewMatrixAxis @relation(fields: [axisId], references: [id], onDelete: Cascade)
  @@index([axisId])
  @@map("overview_matrix_axis_items")
}
model OverviewMatrixCell {
  id String @id @default(uuid())
  matrixId String @map("matrix_id")
  rowItemId String @map("row_item_id")
  colItemId String @map("col_item_id")
  layerItemId String? @map("layer_item_id")   // 第3軸（2軸時null）
  value String? @db.Text                       // TEXT本文 / "C/R/U" / 記号
  note String? @db.Text
  isApplicable Boolean @default(true) @map("is_applicable")
  reason String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  matrix OverviewMatrix @relation(fields: [matrixId], references: [id], onDelete: Cascade)
  @@unique([matrixId, rowItemId, colItemId, layerItemId])
  @@index([matrixId])
  @@map("overview_matrix_cells")
}

// ========================================================================
// 業務イメージ（スライド）ボード
//   図形/矢印/テキスト/画像/手書きを自由配置して ASIS/TOBE の業務の流れを
//   1枚のスライドとしてラフに描く補完ツール（DFD/swimlane/object-map の手前）。
//   キャンバスは Excalidraw(MIT) を埋め込み、ボード単位で scene(JSON) を保存する。
// ========================================================================
enum ImageBoardKind {
  ASIS
  TOBE
}

enum DiagramKind {
  FLOW
  DFD
  OBJECT_MAP
}

enum DiagramElementType {
  IMAGE
  ICON
  TEXT
  SHAPE
  ARROW
}

enum DiagramNodeKind {
  FLOW_NODE
  DFD_NODE
  DATA_OBJECT
}

model ImageBoard {
  id        String         @id @default(uuid())
  projectId String         @map("project_id")
  kind      ImageBoardKind @default(ASIS)
  title     String         @default("")
  order     Int            @default(0)
  // Excalidraw のシーン（{ elements, appState, files }）をそのまま保持する。
  scene     Json?
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("image_boards")
}

// 機能①: 3図共通の装飾フリー要素（移動/リサイズ可な画像など）
model DiagramElement {
  id          String             @id @default(uuid())
  projectId   String             @map("project_id")
  diagramKind DiagramKind        @map("diagram_kind")
  diagramId   String             @map("diagram_id") // FLOW=BusinessFlow.id / DFD=DfdDiagram.id / OBJECT_MAP=projectId
  type        DiagramElementType @default(IMAGE)
  positionX   Float              @default(0) @map("position_x")
  positionY   Float              @default(0) @map("position_y")
  width       Float?
  height      Float?
  rotation    Float              @default(0)
  z           Int                @default(0)
  attachmentId String?           @map("attachment_id")
  text        String             @default("") @db.Text
  color       String?
  style       Json?
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  attachment Attachment? @relation(fields: [attachmentId], references: [id], onDelete: SetNull)
  @@index([projectId])
  @@index([diagramKind, diagramId])
  @@map("diagram_elements")
}

// 機能②: 3図のノードへの添付（ノード側はポリモーフィック=FKなし）
model NodeAttachment {
  id           String          @id @default(uuid())
  projectId    String          @map("project_id")
  nodeKind     DiagramNodeKind @map("node_kind")
  nodeId       String          @map("node_id")
  attachmentId String          @map("attachment_id")
  order        Int             @default(0)
  caption      String?
  createdAt    DateTime        @default(now()) @map("created_at")
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  @@unique([nodeKind, nodeId, attachmentId])
  @@index([projectId])
  @@index([nodeKind, nodeId])
  @@map("node_attachments")
}

// 機能③: KGエンティティ ⟷ 図ノード の橋渡し（net-new）
model KnowledgeNodeLink {
  id              String      @id @default(cuid())
  projectId       String      @map("project_id")
  knowledgeNodeId String      @map("knowledge_node_id")
  diagramKind     DiagramKind @map("diagram_kind")
  diagramNodeId   String      @map("diagram_node_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  knowledgeNode KnowledgeNode @relation(fields: [knowledgeNodeId], references: [id], onDelete: Cascade)
  @@unique([knowledgeNodeId, diagramKind, diagramNodeId])
  @@index([projectId])
  @@index([diagramKind, diagramNodeId])
  @@map("knowledge_node_links")
}

// 業務フローの担当者（ステークホルダー多対多）。MeetingStakeholder と同型。
model FlowStakeholder {
  id            String   @id @default(uuid())
  flowId        String   @map("flow_id")
  stakeholderId String   @map("stakeholder_id")
  order         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")

  flow        BusinessFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  stakeholder Stakeholder  @relation(fields: [stakeholderId], references: [id], onDelete: Cascade)

  @@unique([flowId, stakeholderId])
  @@index([flowId])
  @@index([stakeholderId])
  @@map("flow_stakeholders")
}
