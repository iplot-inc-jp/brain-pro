# ===== Backend 環境変数サンプル =====
# 値は各自の環境に合わせて設定してください（このファイルに実値は入れない）。

# ---- データベース ----
DATABASE_URL=postgresql://user:password@localhost:5432/ai_data_flow?schema=public

# ---- 認証(JWT) ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# 会社をまたぐ最上位権限を持つメール（カンマ区切り）
SUPER_ADMIN_EMAILS=

# ---- サーバ ----
PORT=5021
NODE_ENV=development
# フロントの公開URL（招待リンク等の生成に使用）
FRONTEND_URL=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:5021

# ---- 暗号化 ----
# 会社ごとの API キー等を暗号化する鍵（32バイト相当のランダム文字列）
TOKEN_ENC_KEY=change-me-to-a-32-byte-random-key

# ---- Claude / 抽出 ----
ANTHROPIC_API_KEY=
EXTRACTION_MODEL=claude-sonnet-4-6

# ---- Google ログイン(OAuth) ----
# Google ログイン用 OAuth クライアントID（未設定なら Google ログインは無効=503）
GOOGLE_CLIENT_ID=

# ---- Google Drive 連携(OAuth) ----
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5021/api/integrations/google/callback

# ---- Liveblocks(共同編集) ----
LIVEBLOCKS_SECRET_KEY=

# ---- ストレージ / アップロード ----
BLOB_READ_WRITE_TOKEN=
UPLOAD_DIR=./uploads

# ---- ジョブキュー(QStash) / Cron ----
CRON_SECRET=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
